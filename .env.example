# Apple ID credentials
APPLE_ID=your-apple-id@example.com

# Password: use EITHER plaintext OR pre-obscured (not both)
# Generate obscured:  rclone obscure "your-password"
APPLE_PASSWORD=
APPLE_PASSWORD_OBSCURED=

# rclone remote name
RCLONE_REMOTE=icloudphotos

# iCloud service: "drive" or "photos"
ICLOUD_SERVICE=photos

# Local backup target directory (inside container)
BACKUP_DIR=/data/backup

# iCloud source path (empty = root with PrimarySync + SharedSync)
RCLONE_SOURCE=

# Auto-init: "true" = create rclone config + trigger 2FA via Telegram on first start
INIT_AUTO=false

# Sort photos into YYYY/MM/DD/ folders (true) or keep flat album structure (false)
SORT_BY_DATE=true

# Dry-run: "true" = simulate only, no actual download
DRY_RUN=false

# Max transfer per run, e.g. "500M" (empty = unlimited)
MAX_TRANSFER=

# Backup interval in hours
BACKUP_INTERVAL_HOURS=6

# Auth check interval in minutes
AUTH_CHECK_INTERVAL_MINUTES=60

# Delay before first backup in minutes
FIRST_BACKUP_DELAY_MINUTES=5

# Telegram Bot token from @BotFather
TELEGRAM_BOT_TOKEN=your-bot-token-here

# Telegram chat ID from @userinfobot
TELEGRAM_CHAT_ID=your-chat-id-here

# Timezone
TZ=Europe/Berlin
